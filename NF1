<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<title>Simulador NF Planta (2 Etapas)</title>
<style>
body { font-family: Arial; margin: 20px; }
input { width: 80px; margin: 3px; }
table { border-collapse: collapse; margin-top: 10px; }
td, th { border: 1px solid #ccc; padding: 6px; text-align: center; }
</style>
</head>
<body>

<h2>Simulador Nanofiltración - 2 Etapas</h2>

<h3>Alimentación</h3>
Li: <input id="Li" value="0.53"> %
SO4: <input id="SO4" value="1.15"> %

<h3>Rechazos</h3>
Li: <input id="RLi" value="22"> %
SO4: <input id="RSO4" value="99"> %

<h3>Operación</h3>
Flujo Feed (m3/h): <input id="Qf" value="40"><br>
Recuperación Etapa 1 (%): <input id="Rec1" value="60"><br>
Recuperación Etapa 2 (%): <input id="Rec2" value="50"><br>

<br>
<button onclick="simular()">Simular</button>

<h3>Resultados</h3>
<div id="out"></div>

<script>
function simular(){

let Qf = parseFloat(document.getElementById("Qf").value);

let Cf_Li = parseFloat(document.getElementById("Li").value);
let Cf_SO4 = parseFloat(document.getElementById("SO4").value);

let RLi = parseFloat(document.getElementById("RLi").value)/100;
let RSO4 = parseFloat(document.getElementById("RSO4").value)/100;

let Rec1 = parseFloat(document.getElementById("Rec1").value)/100;
let Rec2 = parseFloat(document.getElementById("Rec2").value)/100;

// Etapa 1
let Qp1 = Qf * Rec1;
let Qr1 = Qf - Qp1;

let Cp1_Li = Cf_Li*(1-RLi);
let Cp1_SO4 = Cf_SO4*(1-RSO4);

let Cr1_Li = (Qf*Cf_Li - Qp1*Cp1_Li)/Qr1;
let Cr1_SO4 = (Qf*Cf_SO4 - Qp1*Cp1_SO4)/Qr1;

// Etapa 2
let Qp2 = Qr1 * Rec2;
let Qr2 = Qr1 - Qp2;

let Cp2_Li = Cr1_Li*(1-RLi);
let Cp2_SO4 = Cr1_SO4*(1-RSO4);

let Cr2_Li = (Qr1*Cr1_Li - Qp2*Cp2_Li)/Qr2;
let Cr2_SO4 = (Qr1*Cr1_SO4 - Qp2*Cp2_SO4)/Qr2;

// Recuperación Li
let Li_feed = Qf*Cf_Li;
let Li_perm = Qp1*Cp1_Li + Qp2*Cp2_Li;

let Rec_Li = Li_perm / Li_feed *100;

// Output
let html = `
<table>
<tr><th>Corriente</th><th>Caudal</th><th>Li %</th><th>SO4 %</th></tr>
<tr><td>P1</td><td>${Qp1.toFixed(2)}</td><td>${Cp1_Li.toFixed(3)}</td><td>${Cp1_SO4.toFixed(3)}</td></tr>
<tr><td>P2</td><td>${Qp2.toFixed(2)}</td><td>${Cp2_Li.toFixed(3)}</td><td>${Cp2_SO4.toFixed(3)}</td></tr>
<tr><td>R2</td><td>${Qr2.toFixed(2)}</td><td>${Cr2_Li.toFixed(3)}</td><td>${Cr2_SO4.toFixed(3)}</td></tr>
</table>

<p><b>Recuperación global agua:</b> ${(Rec1+(1-Rec1)*Rec2)*100.toFixed(1)} %</p>
<p><b>Recuperación Li:</b> ${Rec_Li.toFixed(1)} %</p>
`;

document.getElementById("out").innerHTML = html;
}
</script>

</body>
</html>
